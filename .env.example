# Kopieer dit bestand naar .env.local en vul in wat je gebruikt.
# Alles is optioneel: zonder deze variabelen draait de app in demo-modus.

# Echte AI-chat via de Claude API (console.anthropic.com → API keys).
# Zonder key gebruikt de chat de ingebouwde demo-assistent.
ANTHROPIC_API_KEY=

# Wachtwoordherstel per e-mail via Resend (resend.com — gratis tier volstaat).
# Zonder deze twee toont de app de herstel-link direct op het scherm.
RESEND_API_KEY=
MAIL_FROM="Kompas <onboarding@resend.dev>"
